# Copy to .env and fill in. Never commit the real .env.

# --- Required before first run ---
ANTHROPIC_API_KEY=sk-ant-...
APP_SECRET_TOKEN=change-me-to-a-long-random-string

# --- Recommended ---
CHILD_NAME=Tommy
TIMEZONE=America/New_York

# --- AI model (switch to a stronger model if parsing ever misses) ---
AI_MODEL=claude-haiku-4-5
# e.g. AI_MODEL=claude-sonnet-4-6

# --- Twilio signature validation (turn on in production) ---
TWILIO_VALIDATE=false
TWILIO_AUTH_TOKEN=
# Public HTTPS URL of this app, needed for validation behind a proxy:
PUBLIC_BASE_URL=

# --- Paths ---
DB_PATH=data/readathon.db
CONTACTS_PATH=contacts.json
